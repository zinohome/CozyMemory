# CozyMemory 统一反向代理配置
# 端口说明：
#   :80   → 导航页（服务总览，可点击跳转各端口）
#   :8000 → CozyMemory 统一服务层（REST API + gRPC）
#   :8080 → Cognee（前端 + API）
#   :8081 → Mem0（前端 + API）
#   :8019 → Memobase API

# 导航页 (:80) — 点击跳转各服务端口
:80 {
	root * /srv/nav
	file_server
}

# CozyMemory 统一服务层 (:8000)
# /metrics 不对外暴露（Prometheus 从 compose 内网直接抓 cozymemory:8000/metrics）
:8000 {
	@metrics path /metrics
	respond @metrics "Not Found" 404

	reverse_proxy cozymemory-api:8000
}

# Cognee 生态 (:8080)
:8080 {
	# Cognee API（/api/* 路径优先匹配）
	handle /api/* {
		reverse_proxy cognee:8000
	}
	# Cognee 前端（其余所有路径）
	# header_up Host: 告诉 Next.js dev server 请求来自 localhost，
	# 避免触发 Next.js 16 的 cross-origin allowedDevOrigins 安全检查，
	# 否则浏览器端 HMR WebSocket 连接会被拒绝导致页面无法正常渲染
	handle {
		reverse_proxy cognee-frontend:3000 {
			header_up Host localhost:3000
		}
	}
}

# Mem0 生态 (:8081)
# 注意：mem0-api 路由本身在 /api/v1/*，不裁剪前缀，直接透传
:8081 {
	# Mem0 API
	handle /api/* {
		reverse_proxy mem0-api:8000
	}
	# Mem0 前端
	handle {
		reverse_proxy mem0-webui:3000
	}
}

# Memobase API (:8019)
:8019 {
	reverse_proxy memobase-server-api:8000
}

# CozyMemory UI (:8088)
:8088 {
	header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' *; img-src 'self' data:; font-src 'self' data:"
	header X-Content-Type-Options "nosniff"
	header X-Frame-Options "DENY"
	reverse_proxy cozymemory-ui:3000
}

# Grafana (:3001)
:3001 {
	reverse_proxy grafana:3000
}

# gRPC TLS 终止 (:50051) — Caddy 自签 TLS，内部 h2c 转发到 cozymemory-api
# 客户端连接加密，避免 API Key metadata 在网络上明文传输
localhost:50051 {
	reverse_proxy h2c://cozymemory-api:50051
	tls internal
}

# LLM API 代理 (:9090) — 内部专用，剥除 oneapi.naivehero.top 的重复 Server 响应头
# aiohttp 3.13+ 对重复响应头严格校验，通过此代理解决
:9090 {
	reverse_proxy https://oneapi.naivehero.top {
		header_up Host oneapi.naivehero.top
		header_down -Server
	}
}
