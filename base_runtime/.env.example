# CozyMemory base_runtime 部署配置示例
# 复制为 .env（同目录），按需填入生产值。docker compose 会自动加载
# 紧邻 docker-compose.1panel.yml 的 .env 文件。
#
# 标为 REQUIRED 的必须设置；否则 `docker compose up` 会报错退出。
# 标为 OPTIONAL 的有默认值可回退。

# ==============================================================================
# LLM（REQUIRED）— OpenAI 兼容 API
# ==============================================================================
# 所有引擎（Cognee / Mem0 / Memobase / CozyMemory）共用这一个 key。
# LLM_MODEL / EMBEDDING_MODEL 已在 compose 里写死为 gpt-4.1-nano / text-embedding-3-large，
# 如需调整到其它模型，请在 compose 里改相应字段。
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==============================================================================
# CozyMemory API 鉴权（OPTIONAL）
# ==============================================================================
# 逗号分隔的多个 bootstrap key。非空 = 启用鉴权，所有 /api/v1/*
# 需要 X-Cozy-API-Key header 匹配其中任一。admin 操作只接受这些。
# 动态 key 在 UI Settings 里创建。
# 留空 = 完全关闭鉴权（开发模式）。
COZY_API_KEYS=

# ==============================================================================
# 基础设施密码（REQUIRED — 请使用强密码）
# ==============================================================================
POSTGRES_PASSWORD=change-me-postgres
REDIS_PASSWORD=change-me-redis
NEO4J_PASSWORD=change-me-neo4j
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio

# ==============================================================================
# 应用数据库密码（REQUIRED — init.sh 首次建库时使用）
# ==============================================================================
# 注意：数据库已初始化后修改这些值不会自动更新密码，需手动 ALTER USER
COGNEE_DB_PASSWORD=change-me-cognee-db
MEMOBASE_DB_PASSWORD=change-me-memobase-db
COZYMEMORY_DB_PASSWORD=change-me-cozymemory-db
COGNEE_ADMIN_PASSWORD=change-me-cognee-admin

# ==============================================================================
# CORS（OPTIONAL — 生产环境应限制为具体域名）
# ==============================================================================
# 逗号分隔多个域名；默认 * 允许所有来源（仅限开发）
# 生产示例：CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=*

# ==============================================================================
# Memobase 服务端 token（REQUIRED）
# ==============================================================================
# Memobase admin token。CozyMemory 内部自动带上这个 key 访问 Memobase。
MEMOBASE_ACCESS_TOKEN=change-me-memobase-token

# ==============================================================================
# JWT — Dashboard 开发者登录 (batch 17)
# ==============================================================================
# 生产环境必须改，生成命令：openssl rand -hex 32
JWT_SECRET=change-me-in-production
