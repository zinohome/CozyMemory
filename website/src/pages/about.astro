---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { useTranslations } from '~/i18n';

const t = useTranslations('en');

const GITHUB_URL = 'https://github.com/ZhangJun/CozyMemory';

const metadata = {
  title: 'About — CozyMemory',
};
---

<Layout metadata={metadata}>
  <!-- Hero -->
  <Hero tagline="About CozyMemory">
    <Fragment slot="title">
      {t.about.title}
    </Fragment>

    <Fragment slot="subtitle">
      {t.about.vision}
    </Fragment>
  </Hero>

  <!-- Tech Stack -->
  <Features
    id="tech-stack"
    tagline={t.about.techStack}
    title="Built on a Modern, Battle-Tested Stack"
    subtitle="Every component was chosen for production reliability, developer ergonomics, and observability."
    items={[
      {
        title: 'Python 3.11+',
        description: 'Async-first FastAPI + gRPC server. Pydantic v2 models, ruff linting, mypy strict typing.',
        icon: 'tabler:brand-python',
      },
      {
        title: 'Next.js 16 + React 19',
        description: 'App Router admin UI with TanStack Query, Zustand, Base UI, shadcn, and Tailwind v4.',
        icon: 'tabler:brand-nextjs',
      },
      {
        title: 'Docker + Docker Compose',
        description: 'One-click deploy: 15 containers — CozyMemory API, three engines, PostgreSQL/pgvector, Redis, Qdrant, MinIO, Neo4j.',
        icon: 'tabler:brand-docker',
      },
      {
        title: 'PostgreSQL + pgvector',
        description: 'Primary relational store plus vector similarity search. Mem0 and Memobase persist data here.',
        icon: 'tabler:database',
      },
      {
        title: 'Prometheus + Grafana',
        description: 'Built-in metrics collection with alerting rules and dashboards out of the box — no extra setup.',
        icon: 'tabler:chart-line',
      },
      {
        title: 'REST + gRPC',
        description: '19 REST endpoints and 18 gRPC methods sharing the same service layer. Both protocols are production-ready.',
        icon: 'tabler:api',
      },
    ]}
  />

  <!-- License + Contributing -->
  <Content
    tagline="Open Source"
    title={t.about.license}
    items={[
      {
        title: 'AGPL-3.0-or-later',
        description: t.about.licenseText,
      },
      {
        title: t.about.contributing,
        description: t.about.contributingText,
      },
      {
        title: 'Issue Tracker',
        description: 'Found a bug or have a feature request? Open an issue on GitHub. We triage and respond promptly.',
      },
    ]}
    image={{
      src: '~/assets/images/screenshot-dashboard.png',
      alt: 'CozyMemory Dashboard',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Free to use, free to fork
      </h3>
      CozyMemory is open-source under AGPL-3.0. You can self-host it, contribute improvements,
      or build commercial products on top — as long as modifications to CozyMemory itself remain open.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- CTA -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'View on GitHub',
        href: GITHUB_URL,
        target: '_blank',
        icon: 'tabler:brand-github',
      },
      {
        text: 'Report an Issue',
        href: `${GITHUB_URL}/issues`,
        target: '_blank',
        icon: 'tabler:bug',
      },
    ]}
  >
    <Fragment slot="title">
      Get involved with CozyMemory
    </Fragment>

    <Fragment slot="subtitle">
      Star the repo, open an issue, or submit a pull request. Every contribution helps make AI memory better for everyone.
    </Fragment>
  </CallToAction>
</Layout>
