---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Note from '~/components/widgets/Note.astro';
import Stats from '~/components/widgets/Stats.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import { useTranslations } from '~/i18n';

const t = useTranslations('en');

const GITHUB_URL = 'https://github.com/zinohome/CozyMemory';
const GITHUB_DOCS = 'https://github.com/zinohome/CozyMemory/tree/main/docs';

const metadata = {
  title: 'CozyMemory — Unified AI Memory for Every LLM App',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: t.hero.getStarted,
        href: GITHUB_URL,
        target: '_blank',
        icon: 'tabler:brand-github',
      },
      {
        text: t.hero.apiDocs,
        href: GITHUB_DOCS,
        target: '_blank',
        icon: 'tabler:book',
      },
    ]}
    image={{ src: '~/assets/images/screenshot-dashboard.png', alt: 'CozyMemory Dashboard' }}
  >
    <Fragment slot="title">
      {t.hero.title}
    </Fragment>

    <Fragment slot="subtitle">
      {t.hero.subtitle}
    </Fragment>
  </Hero>

  <!-- Three Engines Features -->
  <Features
    id="engines"
    tagline="Three Memory Engines"
    title="One API — Three Specialized Backends"
    subtitle="CozyMemory routes your requests to the right engine automatically, so you get the best of each without managing three integrations."
    items={[
      {
        title: t.engines.mem0.name,
        description: `${t.engines.mem0.tagline}. ${t.engines.mem0.items.join(' · ')}`,
        icon: 'tabler:brain',
      },
      {
        title: t.engines.memobase.name,
        description: `${t.engines.memobase.tagline}. ${t.engines.memobase.items.join(' · ')}`,
        icon: 'tabler:user-circle',
      },
      {
        title: t.engines.cognee.name,
        description: `${t.engines.cognee.tagline}. ${t.engines.cognee.items.join(' · ')}`,
        icon: 'tabler:topology-star-3',
      },
    ]}
  />

  <!-- Quick Integration Note -->
  <Note
    title="Quick Integration:"
    description="pip install httpx · client.post('/api/v1/conversations', json={'user_id': 'u1', 'messages': [{'role': 'user', 'content': 'I love Python'}]}) · # Done — memory extracted automatically"
  />

  <!-- Stats -->
  <Stats
    stats={[
      { title: t.stats.engines, amount: '3' },
      { title: t.stats.endpoints, amount: '50+' },
      { title: t.stats.tests, amount: '524' },
      { title: t.stats.protocols, amount: '2' },
    ]}
  />

  <!-- Why CozyMemory Features -->
  <Features
    id="features"
    tagline="Why CozyMemory?"
    title={t.why.title}
    subtitle="Built for production SaaS: multi-tenant isolation, full observability, self-hosted deployment."
    items={[
      {
        title: t.why.unified.title,
        description: t.why.unified.description,
        icon: 'tabler:api',
      },
      {
        title: t.why.multiTenant.title,
        description: t.why.multiTenant.description,
        icon: 'tabler:building',
      },
      {
        title: t.why.selfHosted.title,
        description: t.why.selfHosted.description,
        icon: 'tabler:server',
      },
      {
        title: t.why.observable.title,
        description: t.why.observable.description,
        icon: 'tabler:chart-line',
      },
    ]}
  />

  <!-- Dashboard Content -->
  <Content
    isReversed
    tagline="Admin Dashboard"
    title="Everything in One Place"
    items={[
      {
        title: 'Memory Explorer',
        description: 'Browse, search, and delete conversation memories for any user across your apps.',
      },
      {
        title: 'Profile Manager',
        description: 'View structured user profiles with topic-based organization and manual edit support.',
      },
      {
        title: 'Knowledge Base',
        description: 'Manage datasets, trigger knowledge graph builds, and search with multiple modes.',
      },
      {
        title: 'Playground',
        description: 'Test the unified /context endpoint interactively and preview LLM-ready memory prompts.',
      },
    ]}
    image={{
      src: '~/assets/images/screenshot-dashboard.png',
      alt: 'CozyMemory Admin Dashboard',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Full visibility into all three memory layers
      </h3>
      The Next.js admin UI gives operators and developers a single pane of glass over conversations, profiles, and knowledge graphs.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Latest Blog Posts -->
  <BlogLatestPosts
    title="From the Blog"
    information="Release notes, architecture deep dives, and integration guides for CozyMemory."
  />

  <!-- CTA -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: t.cta.starOnGithub,
        href: GITHUB_URL,
        target: '_blank',
        icon: 'tabler:brand-github',
      },
      {
        text: t.cta.readTheDocs,
        href: GITHUB_DOCS,
        target: '_blank',
        icon: 'tabler:book',
      },
    ]}
  >
    <Fragment slot="title">
      Start building with<br class="block sm:hidden" /> <span class="sm:whitespace-nowrap">CozyMemory</span>
    </Fragment>

    <Fragment slot="subtitle">
      Self-hosted, open-source, and production-ready. Deploy in minutes with Docker Compose.
    </Fragment>
  </CallToAction>
</Layout>
