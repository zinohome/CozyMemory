# ==================== 应用配置 ====================
APP_NAME=CozyMemory
APP_VERSION=2.0.0
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
GRPC_PORT=50051

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ==================== Mem0 引擎 ====================
MEM0_API_URL=http://localhost:8888
MEM0_API_KEY=
MEM0_TIMEOUT=30.0
MEM0_ENABLED=true

# ==================== Memobase 引擎 ====================
MEMOBASE_API_URL=http://localhost:8019
MEMOBASE_API_KEY=secret
MEMOBASE_TIMEOUT=60.0
MEMOBASE_ENABLED=true

# ==================== Cognee 引擎 ====================
COGNEE_API_URL=http://localhost:8000
COGNEE_API_KEY=
COGNEE_TIMEOUT=300.0
COGNEE_ENABLED=true

# ==================== Redis（用户 ID 映射） ====================
# Memobase 要求 UUID v4，CozyMemory 通过 Redis 透明映射任意 user_id
REDIS_URL=redis://localhost:6379/0
REDIS_USER_MAPPING_TTL=0   # 0 = 永不过期；正整数 = TTL（秒）