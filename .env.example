# CozyMemory 环境配置示例
# 复制此文件为 .env 并修改相应配置

# ==================== 应用配置 ====================
APP_NAME=CozyMemory
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=True

# ==================== 服务配置 ====================
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ==================== 数据库配置 ====================
# 开发环境使用 SQLite
DATABASE_URL=sqlite+aiosqlite:///./cozymemory.db

# 生产环境使用 PostgreSQL
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/cozymemory

# ==================== Redis 配置 ====================
REDIS_URL=redis://localhost:6379/0
REDIS_PREFIX=cozymemory:
CACHE_TTL=300

# ==================== 记忆引擎配置 ====================
# Memobase
MEMOBASE_ENABLED=True
MEMOBASE_API_URL=http://localhost:8001
MEMOBASE_API_KEY=

# Mem0
MEM0_ENABLED=False
MEM0_API_URL=http://localhost:8002
MEM0_API_KEY=

# Cognee
COGNEE_ENABLED=False
COGNEE_API_URL=http://localhost:8003
COGNEE_API_KEY=

# ==================== 智能路由配置 ====================
ROUTER_STRATEGY=intent
ROUTER_TIMEOUT=5.0
FUSION_STRATEGY=rrf

# ==================== 日志配置 ====================
LOG_LEVEL=DEBUG
LOG_FORMAT=text
# LOG_FILE=logs/cozymemory.log

# ==================== 监控配置 ====================
PROMETHEUS_ENABLED=True
PROMETHEUS_PORT=9090

# ==================== 安全配置 ====================
API_KEY_HEADER=X-API-Key
# 生产环境配置具体域名
# CORS_ORIGINS=["https://api.cozymemory.com"]
RATE_LIMIT=100

# ==================== 性能配置 ====================
MAX_BATCH_SIZE=100
ASYNC_QUEUE_SIZE=1000
MAX_CONCURRENT_REQUESTS=100
