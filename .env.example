# ==================== 应用配置 ====================
APP_NAME=CozyMemory
APP_VERSION=2.0.0
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
GRPC_PORT=50051

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ==================== Mem0 引擎 ====================
MEM0_API_URL=http://localhost:8888
MEM0_API_KEY=
MEM0_TIMEOUT=30.0
MEM0_ENABLED=true

# ==================== Memobase 引擎 ====================
MEMOBASE_API_URL=http://localhost:8019
MEMOBASE_API_KEY=secret
MEMOBASE_TIMEOUT=60.0
MEMOBASE_ENABLED=true

# ==================== Cognee 引擎 ====================
COGNEE_API_URL=http://localhost:8000
COGNEE_API_KEY=
COGNEE_TIMEOUT=300.0
COGNEE_ENABLED=true
COGNEE_USER_EMAIL=admin@cognee.com
COGNEE_USER_PASSWORD=

# ==================== Redis（用户 ID 映射） ====================
# Memobase 要求 UUID v4，CozyMemory 通过 Redis 透明映射任意 user_id
REDIS_URL=redis://localhost:6379/0
REDIS_USER_MAPPING_TTL=0   # 0 = 永不过期；正整数 = TTL（秒）

# ==================== PostgreSQL 平台库 ====================
DATABASE_URL=postgresql+asyncpg://cozymemory_user:cozymemory_pass@localhost:5433/cozymemory

# ==================== JWT（Dashboard 登录） ====================
JWT_SECRET=change-me-in-production   # 生产必须改！APP_ENV=production 时强制校验
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_SECONDS=86400   # 24h

# ==================== API Key 鉴权 ====================
# 逗号分隔多个 key，留空 = 鉴权关闭（开发模式）
COZY_API_KEYS=

# ==================== 速率限制 ====================
RATE_LIMIT_PER_MINUTE=600   # 0 = 不限制；per-App sliding window
RATE_LIMIT_BURST=100
