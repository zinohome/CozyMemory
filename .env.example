# ==================== 应用配置 ====================
APP_NAME=CozyMemory
APP_VERSION=2.0.0
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
GRPC_PORT=50051

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ==================== Mem0 引擎 ====================
MEM0_API_URL=http://localhost:8888
MEM0_API_KEY=
MEM0_TIMEOUT=30.0
MEM0_ENABLED=true

# ==================== Memobase 引擎 ====================
MEMOBASE_API_URL=http://localhost:8019
MEMOBASE_API_KEY=secret
MEMOBASE_TIMEOUT=60.0
MEMOBASE_ENABLED=true

# ==================== Cognee 引擎 ====================
COGNEE_API_URL=http://localhost:8000
COGNEE_API_KEY=
COGNEE_TIMEOUT=300.0
COGNEE_ENABLED=true